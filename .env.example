DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# KZ Gamedata source (pick one)
# Option A: fetch directly from GitHub on every poll (default, no config needed)
# KZ_GAMEDATA_URL=https://raw.githubusercontent.com/KZGlobalTeam/cs2kz-metamod/master/gamedata/cs2kz-core.games.txt

# Option B: use a local file
# KZ_GAMEDATA_LOCAL=/path/to/cs2kz-metamod/gamedata/cs2kz-core.games.txt

POLL_INTERVAL=60

# Set to 1 to skip vtable/vfunc scanning
SKIP_VFUNC=0

# Set to 1 to skip offset validation
SKIP_OFFSETS=0

# Control which results are posted to the Discord webhook (1=on, 0=off)
NOTIFY_VFUNC=1
NOTIFY_PATTERNS=1
NOTIFY_OFFSETS=1
