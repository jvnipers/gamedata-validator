# Discord Webhooks — comma-separated list of webhook names
# Each webhook gets its own URL, NOTIFY_* flags, and ATTACH_JSON setting.
# Format: <NAME>_WEBHOOK_URL, <NAME>_NOTIFY_VFUNC, <NAME>_NOTIFY_PATTERNS, etc.
# All NOTIFY_* and ATTACH_JSON default to 1 if not specified.
#
# Legacy fallback: if DISCORD_WEBHOOKS is not set, a single DISCORD_WEBHOOK
# var is used with global NOTIFY_VFUNC / NOTIFY_PATTERNS / WEBHOOK_ATTACH_JSON.

DISCORD_WEBHOOKS=main
MAIN_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE
MAIN_NOTIFY_VFUNC=1
MAIN_NOTIFY_PATTERNS=1
MAIN_ATTACH_JSON=1
MAIN_PATTERNS_ONLY_ON_FAILURE=1

# Example: add another webhook that only receives pattern scan results
# DISCORD_WEBHOOKS=main,alerts
# ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERTS_NOTIFY_VFUNC=0
# ALERTS_NOTIFY_PATTERNS=1
# ALERTS_ATTACH_JSON=1

# KZ Gamedata source (pick one)
# Option A: fetch directly from GitHub on every poll (default, no config needed)
# KZ_GAMEDATA_URL=https://raw.githubusercontent.com/KZGlobalTeam/cs2kz-metamod/master/gamedata/cs2kz-core.games.txt

# Option B: use a local file
# KZ_GAMEDATA_LOCAL=/path/to/cs2kz-metamod/gamedata/cs2kz-core.games.txt

POLL_INTERVAL=60

# Set to 1 to skip vtable/vfunc scanning
SKIP_VFUNC=0
